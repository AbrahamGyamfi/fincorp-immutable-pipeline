# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Database ──────────────────────────────────────────────
# Replace <password> with the db_password from terraform.tfvars
DATABASE_URL=postgres://fincorp_admin:<password>@fincorp-primary.czcaik68aayt.eu-west-1.rds.amazonaws.com:5432/fincorp

# ── AWS ───────────────────────────────────────────────────
AWS_REGION=eu-west-1
DR_REGION=eu-central-1

# ECR
ECR_REPOSITORY=fincorp-api
ECR_REGISTRY=195275667627.dkr.ecr.eu-west-1.amazonaws.com

# RDS identifier (ARN resolved automatically via DescribeDBInstances)
PRIMARY_DB_ID=fincorp-primary

# CodeArtifact
CODEARTIFACT_DOMAIN=fincorp
CODEARTIFACT_DOMAIN_OWNER=195275667627
