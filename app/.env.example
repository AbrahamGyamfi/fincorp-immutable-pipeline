# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Database ──────────────────────────────────────────────
# Get endpoint from: terraform output primary_db_endpoint
# Get credentials from terraform.tfvars (db_username / db_password)
DATABASE_URL=postgres://<db_username>:<db_password>@<terraform-output-primary_db_endpoint>/fincorp

# ── AWS ───────────────────────────────────────────────────
AWS_REGION=eu-west-1
DR_REGION=eu-central-1

# Get from: terraform output ecr_registry
ECR_REGISTRY=<account-id>.dkr.ecr.eu-west-1.amazonaws.com
ECR_REPOSITORY=fincorp-api

# RDS identifier (ARN resolved automatically via DescribeDBInstances)
PRIMARY_DB_ID=fincorp-primary

# Get from: terraform output (domain and domain_owner)
CODEARTIFACT_DOMAIN=fincorp
CODEARTIFACT_DOMAIN_OWNER=<account-id>
