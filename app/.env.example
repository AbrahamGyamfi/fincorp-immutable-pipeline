# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────
# Primary:  postgres://user:pass@<rds-endpoint>:5432/fincorp
# DR:       postgres://user:pass@<dr-rds-endpoint>:5432/fincorp
DATABASE_URL=

# ── AWS ───────────────────────────────────────────────────
AWS_REGION=eu-west-1
DR_REGION=eu-central-1

# ECR
ECR_REPOSITORY=fincorp-api
ECR_REGISTRY=<account-id>.dkr.ecr.eu-west-1.amazonaws.com

# RDS (identifier only — ARN is resolved automatically from DescribeDBInstances)
PRIMARY_DB_ID=fincorp-primary
